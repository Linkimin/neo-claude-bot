# Copy to .env (git-ignored) and fill in. Required vars have no default.
#
# NOTE: Claude authentication is NOT configured here. The bot drives your
# locally installed Claude Code, which reads ~/.claude/.credentials.json.
# Log in once on the desktop (`claude` -> /login) and the bot inherits it.

# --- Required ---
# BotFather token for your Telegram bot.
TELEGRAM_BOT_TOKEN=
# Your Telegram numeric user id (the only account allowed to use the bot).
TELEGRAM_USER_ID=
# Id of the forum supergroup with Topics enabled (negative, e.g. -1001234567890).
TELEGRAM_GROUP_ID=
# PIN that unlocks the auto/bypass-permissions mode from the bot (/auto <PIN>).
SETTINGS_PIN=

# --- Optional: model failover to a secondary provider ---
# If ROUTERAI_API_KEY is unset, failover is disabled.
# routerai.ru is OpenAI-format and is bridged to Anthropic via claude-code-router.
ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=
# Local claude-code-router proxy port (default 3456).
CCR_PORT=3456

# --- Optional: spend / balance alerts ---
# Daily estimated-spend threshold in USD; alert once per day when exceeded.
SPEND_ALERT_USD=
# Low-balance threshold (routerai credits); alert when balance drops below it.
ROUTERAI_BALANCE_MIN=
